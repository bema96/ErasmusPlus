{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "news",
    "pluralName": "articles",
    "displayName": "News"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "image": {
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ],
      "type": "media",
      "multiple": true
    },
    "titel": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "date": {
      "type": "date"
    },
    "location": {
      "type": "customField",
      "options": {
        "info": true
      },
      "customField": "plugin::geodata.geojson"
    }
  }
}
